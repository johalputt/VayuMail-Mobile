<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup/transfer rules, referenced from the manifest as
  android:dataExtractionRules="@xml/data_extraction_rules" (audit L12).

  The app sets android:allowBackup="false", so cloud backup and device-to-device
  transfer are already disabled outright. These rules are defence in depth: if
  backup is ever re-enabled, the sensitive at-rest files — the SQLite database
  and the sealed keystore + its key — must never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="file" path="vayumail" />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="file" path="vayumail" />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
